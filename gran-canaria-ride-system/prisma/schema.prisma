// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // when calling backend uncomment the line below
  url      = env("DATABASE_URL")
  
}

model User {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255)
  points    Int       @default(0)
  isAdmin   Boolean   @default(false)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  redemptions Redemption[]
  userChallenges UserChallenge[]
}

model Ride {
  id          Int       @id @default(autoincrement())
  name        String
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  capacity    Int
  duration    Int       // minutes
  location    String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reward {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(150)
  description String   @db.Text
  cost        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  redemptions Redemption[]
}

model Redemption {
  id        Int      @id @default(autoincrement())
  userId    Int
  rewardId  Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])
}

model Challenge {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(150)
  description  String   @db.Text
  type         String   @db.VarChar(20) // "daily" or "weekly"
  goal         Int      // Target value (e.g., 5000 steps, 10 km)
  goalUnit     String   @db.VarChar(20) // "steps", "km", "minutes"
  rewardPoints Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userChallenges UserChallenge[]
}

model UserChallenge {
  id          Int      @id @default(autoincrement())
  userId      Int
  challengeId Int
  status      String   @db.VarChar(20) @default("active") // "active", "completed", "expired"
  progress    Int      @default(0) // Current progress towards goal
  startedAt   DateTime @default(now())
  completedAt DateTime?
  expiresAt   DateTime // When the challenge expires
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
}